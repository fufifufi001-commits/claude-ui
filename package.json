{
  "name": "claude-ui-v2",
  "version": "2.0.0",
  "description": "Claude Code Developer Studio - Terminal, Preview & Visual Testing",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac",
    "dev": "electron . --dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^0.10.1"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.claudeui.studio",
    "productName": "Claude UI Studio",
    "files": [
      "main.js",
      "src/**/*",
      "node_modules/@xterm/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "zip",
      "category": "public.app-category.developer-tools"
    }
  }
}
